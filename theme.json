{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1120px"
    },
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "palette": [
        {
          "name": "Background",
          "slug": "background",
          "color": "#090b12"
        },
        {
          "name": "Background Soft",
          "slug": "background-soft",
          "color": "#111522"
        },
        {
          "name": "Text",
          "slug": "text",
          "color": "#f4f7fb"
        },
        {
          "name": "Text Muted",
          "slug": "text-muted",
          "color": "#a7b0c2"
        },
        {
          "name": "Accent",
          "slug": "accent",
          "color": "#6ee7ff"
        },
        {
          "name": "Accent Strong",
          "slug": "accent-strong",
          "color": "#8b5cf6"
        }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "name": "System UI",
          "slug": "system-ui",
          "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem"
        },
        {
          "name": "Base",
          "slug": "base",
          "size": "1rem"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.25rem"
        },
        {
          "name": "Extra Large",
          "slug": "extra-large",
          "size": "2rem"
        }
      ]
    },
    "spacing": {
      "units": [
        "px",
        "rem",
        "em",
        "%",
        "vw",
        "vh"
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#090b12",
      "text": "#f4f7fb"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-ui)",
      "fontSize": "1rem",
      "lineHeight": "1.6"
    },
    "elements": {
      "link": {
        "color": {
          "text": "#6ee7ff"
        }
      },
      "heading": {
        "color": {
          "text": "#f4f7fb"
        },
        "typography": {
          "lineHeight": "1.1"
        }
      }
    }
  }
}